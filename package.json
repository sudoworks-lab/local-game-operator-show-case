{
  "name": "local-game-operator",
  "productName": "local-game-operator",
  "version": "1.0.0",
  "description": "Windows-local Electron game operation assistant MVP",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "build": "node --no-warnings scripts/build-ops.mjs",
    "test": "node --no-warnings --test tests/*.test.ts",
    "ops": "node --no-warnings src/cli.ts",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts .",
    "typecheck": "tsc --noEmit",
    "helper:list-windows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./tools/windows/input-bridge.ps1 list-windows"
  },
  "keywords": [],
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "electron": "41.1.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  }
}
